ANTHROPIC_API_KEY=sk-ant-...
MODEL_NAME=claude-haiku-4-5-20251001
HF_TOKEN=hf_...   # optional — suppresses HuggingFace anonymous-download warning

# --- Evaluation (LLM-as-judge, shared by Approach A & B) ---
JUDGE_MODEL_NAME=claude-sonnet-5   # stronger model grades debates; never grades itself
EVAL_CACHE_DEBATES=true            # cache each topic's debate transcript locally
                                    # (tests/deepeval_promptfoo/.debate_cache/) so
                                    # reruns only pay for judge scoring; set false
                                    # to force a live debate every run

# --- Approach B: hosted LangSmith evaluation (tests/lang_smith/) ---
LANGSMITH_API_KEY=lsv2_...
LANGCHAIN_TRACING_V2=true          # auto-traces each LangGraph node to LangSmith
LANGCHAIN_PROJECT=debate-bot-evals # optional — groups runs in the LangSmith UI
